# ===========================================
# Portfolio .gitignore
# Best practices for React projects
# ===========================================

# -------------------------------------------
# Dependencies
# -------------------------------------------
/node_modules
/.pnp
.pnp.js

# -------------------------------------------
# Build outputs
# -------------------------------------------
/build
/dist
/.next
/.nuxt
/.cache

# -------------------------------------------
# Testing
# -------------------------------------------
/coverage
*.lcov

# -------------------------------------------
# IDEs and editors
# -------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -------------------------------------------
# OS generated files
# -------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -------------------------------------------
# Environment files
# -------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# -------------------------------------------
# Logs
# -------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# -------------------------------------------
# TypeScript cache
# -------------------------------------------
*.tsbuildinfo

# -------------------------------------------
# Temporary files
# -------------------------------------------
*.tmp
*.temp
.cache/

# -------------------------------------------
# Misc
# -------------------------------------------
.vercel
.netlify
